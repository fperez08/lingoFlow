// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/copilot-cli:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"forwardPorts": [
		3000
	],
	"portsAttributes": {
		"3000": {
			"label": "Next.js dev server",
			"onAutoForward": "openPreview"
		}
	},
	"mounts": [
		"source=lingoflow-pnpm-store,target=/home/node/.pnpm-store,type=volume"
	],
	"containerEnv": {
		"NEXT_TELEMETRY_DISABLED": "1"
	},
	"postCreateCommand": "corepack pnpm install && sudo npm install -g @playwright/cli@latest && sudo npm install -g @aisuite/chub && corepack pnpm exec playwright install chromium",
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"bradlc.vscode-tailwindcss",
				"ms-playwright.playwright",
				"Orta.vscode-jest"
			],
			"settings": {
				"eslint.validate": [
					"javascript",
					"javascriptreact",
					"typescript",
					"typescriptreact"
				],
				"editor.codeActionsOnSave": {
					"source.fixAll.eslint": "explicit"
				}
			}
		}
	}
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "yarn install",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}